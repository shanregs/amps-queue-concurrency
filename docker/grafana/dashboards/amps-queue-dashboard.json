{
  "title": "AMPS Queue Concurrency",
  "uid": "amps-queue-main",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Messages Processed (total)",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum(amps_publisher_messages_published_total)",
        "legendFormat": "published"
      }],
      "options": { "colorMode": "value", "graphMode": "area" }
    },
    {
      "id": 2, "type": "stat", "title": "Publish Errors",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum(amps_publisher_messages_errors_total)",
        "legendFormat": "errors"
      }],
      "options": { "colorMode": "value", "thresholds": { "steps": [{"color":"green","value":0},{"color":"red","value":1}] } }
    },
    {
      "id": 3, "type": "stat", "title": "Active Publisher Workers",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "amps_publisher_active_workers",
        "legendFormat": "workers"
      }]
    },
    {
      "id": 4, "type": "timeseries", "title": "Publish Rate (msg/s)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "rate(amps_publisher_messages_published_total[30s])",
        "legendFormat": "published/s"
      },{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "rate(amps_publisher_messages_errors_total[30s])",
        "legendFormat": "errors/s"
      }],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 5, "type": "timeseries", "title": "Publish Latency (p50/p95/p99)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "histogram_quantile(0.50, rate(amps_publisher_publish_duration_seconds_bucket[1m]))",
        "legendFormat": "p50"
      },{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "histogram_quantile(0.95, rate(amps_publisher_publish_duration_seconds_bucket[1m]))",
        "legendFormat": "p95"
      },{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "histogram_quantile(0.99, rate(amps_publisher_publish_duration_seconds_bucket[1m]))",
        "legendFormat": "p99"
      }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 6, "type": "timeseries", "title": "JVM Virtual Threads (live)",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 7 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "jvm_threads_live_threads",
        "legendFormat": "{{application}} live threads"
      }]
    },
    {
      "id": 7, "type": "timeseries", "title": "JVM Heap Used",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 7 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "jvm_memory_used_bytes{area=\"heap\"}",
        "legendFormat": "{{application}} heap"
      }],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 8, "type": "logs", "title": "Application Logs (Loki)",
      "gridPos": { "x": 0, "y": 19, "w": 24, "h": 10 },
      "targets": [{
        "datasource": { "type": "loki", "uid": "loki" },
        "expr": "{service=~\"app.*\"} | json | level != \"DEBUG\"",
        "legendFormat": ""
      }],
      "options": { "showTime": true, "showLabels": true, "sortOrder": "Descending" }
    }
  ]
}
